rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Default: authenticated users can only read/write within their own folder.
    // Tighten or extend per-path as real upload flows are added.
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else by default until explicit rules are added.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
