rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default: authenticated users can only read/write their own user document.
    // Tighten or extend per-collection as real data models are added.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else by default until explicit rules are added.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
